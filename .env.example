# ==========================================
# LUMINA SPHERE - ENVIRONMENT VARIABLES
# ==========================================
# Copiá este archivo a .env y completá tus claves.
# NUNCA subas tu .env real al repo (ya está en .gitignore).
#
# Leyenda:  [REQUERIDA] = sin esto la app no arranca o falla la feature core
#           [opcional]  = la app funciona sin esto (usa fallback / oculta la feature)

# ==========================================
# BASE DE DATOS (Supabase / PostgreSQL)  [REQUERIDA]
# ==========================================
# Supabase Dashboard -> Project Settings -> Database -> Connection string
#   DATABASE_URL = Transaction pooler (puerto 6543) + ?pgbouncer=true  (runtime)
#   DIRECT_URL   = conexión directa (puerto 5432)                      (migraciones)
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ==========================================
# AUTENTICACIÓN (NextAuth v5)  [REQUERIDA]
# ==========================================
# Secreto para firmar sesiones. Generá uno con: openssl rand -base64 32
AUTH_SECRET="genera_un_secreto_de_minimo_32_chars"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"

# Login con Google [opcional]. Si quedan vacíos, se usa solo email + contraseña.
# Redirect URI a configurar en Google Cloud: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ==========================================
# IA (Google Gemini - free tier)  [REQUERIDA]
# ==========================================
# Potencia el chat con personajes y el análisis de "vibe".
# Sacá tu clave gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="tu_gemini_api_key"

# ==========================================
# SERVICIOS EXTERNOS  [opcionales]
# ==========================================
# Películas reales para el Vibe Engine
TMDB_API_KEY=""
TMDB_BASE_URL="https://api.themoviedb.org/3"

# Playlists reales para el Vibe Engine
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Búsqueda de libros y bestsellers en Discover
GOOGLE_BOOKS_API_KEY=""
NYT_API_KEY=""

# Open Library y Project Gutenberg (no requieren clave)
OPEN_LIBRARY_BASE_URL="https://openlibrary.org"
GUTENBERG_BASE_URL="https://www.gutenberg.org"

# Traducción de capítulos [opcional]
DEEPL_API_KEY=""
DEEPL_BASE_URL="https://api-free.deepl.com/v2"

# ==========================================
# APP  [opcional]
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"
